# Case PM — security environment (on-premises or cloud)
# Copy to your server environment or set before starting run.bat

# === Required for production (item 1) ===
# Generate: python -c "import secrets; print(secrets.token_hex(48))"
# CASEPM_SECRET_KEY=your-long-random-secret-here

# === HTTPS / remote access (items 4 — cloud or on-prem with SSL) ===
# On company server behind nginx/IIS with SSL:
#   CASEPM_HTTPS=1
#   CASEPM_BEHIND_PROXY=1
# On cloud (AWS ALB, Azure App Gateway, Cloudflare):
#   CASEPM_HTTPS=1
#   CASEPM_BEHIND_PROXY=1
#   CASEPM_DEPLOYMENT=cloud

# Restrict Host header (comma-separated hostnames)
# CASEPM_ALLOWED_HOSTS=casepm.yourcompany.com,192.168.1.50

# === Developer allowlist (not admins) ===
# CASEPM_DEVELOPER_EMAILS=you@company.com

# === Recovery (break-glass — use SETUP-RECOVERY-ACCESS.bat instead when possible) ===
# CASEPM_RECOVERY_EMAIL=recovery@yourcompany.com
# CASEPM_RECOVERY_PASSWORD=long-random-password

# === Session ===
# CASEPM_SESSION_HOURS=12

# === Microsoft 365 / Outlook (Email module OAuth) ===
# Register redirect URI in Azure App Registration:
#   https://your-casepm-host/api/email/oauth/microsoft/callback
# MICROSOFT_CLIENT_ID=your-azure-app-client-id
# MICROSOFT_CLIENT_SECRET=your-azure-app-client-secret
# MICROSOFT_TENANT_ID=common
# (Aliases: AZURE_CLIENT_ID, AZURE_CLIENT_SECRET, AZURE_TENANT_ID)
